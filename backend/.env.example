ENV=dev
DATA_MODE=mock                 # mock | live
DEFAULT_MARKET=GLOBAL          # US | IN | GLOBAL
AI_PROVIDER=ollama             # ollama | anthropic | openai | mock

DATABASE_URL=postgresql+asyncpg://sdi:sdi@postgres:5432/sdi
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Ollama (local LLM — no API cost)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# Optional free-tier keys (leave blank to stay on mock fallbacks)
# Fallback chain: yfinance → Finnhub → Alpha Vantage → mock
FINNHUB_API_KEY=               # Free: https://finnhub.io/register (60 calls/min)
ALPHAVANTAGE_API_KEY=          # Free: https://www.alphavantage.co/support/#api-key (25 calls/day)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Auth ---
# Leave AUTH_SECRET blank for dev (X-User-Id header / "demo" user).
# Set a strong secret in production to require Bearer JWTs.
AUTH_SECRET=
AUTH_ALGORITHM=HS256
AUTO_CREATE_TABLES=true
